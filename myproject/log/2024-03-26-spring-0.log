2024-03-26 22:19:27.236  INFO 27372 --- [http-nio-8080-exec-3] (85458344340492288) com.example.filter.RequestLogFilter      : 请求处理耗时: 4ms | 响应结果: {"id":85458344340492288,"code":200,"data":[{"id":22,"type":4,"title":"我和魏禹征结婚了！！！！","text":"\n嘿嘿\n","images":["http://localhost:8080/images/cache/20240325/a71230499b67445c9041814ff2550bc3"],"time":"2024-03-25T06:15:41.000+00:00","uid":1,"email":"3061588683@qq.com","username":"test","avatar":"","like":2,"collect":0},{"id":21,"type":1,"title":"新人报道，请多指教嘻嘻","text":"大家好，我今天第一次注册，请问需要注意什么？\n交换机hi规格i北京户口包裹托运\n","images":[],"time":"2024-03-23T13:34:46.000+00:00","uid":2,"email":"nagocoler@qq.com","username":"user","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":1,"collect":0},{"id":20,"type":1,"title":"新人报道，请多指教嘻嘻","text":"大家好，我今天第一次注册，请问需要注意什么？\n","images":[],"time":"2024-03-23T13:29:20.000+00:00","uid":2,"email":"nagocoler@qq.com","username":"user","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":0,"collect":0},{"id":19,"type":1,"title":"dadadad","text":"hhhhh\n","images":[],"time":"2024-03-23T13:08:29.000+00:00","uid":1,"email":"3061588683@qq.com","username":"test","avatar":"","like":1,"collect":0},{"id":18,"type":1,"title":"新人报道，请多指教","text":"大家好，我今天第一次注册，请问需要注意什么？\n","images":[],"time":"2023-10-28T10:23:03.000+00:00","uid":2,"email":"nagocoler@qq.com","username":"user","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":2,"collect":0},{"id":16,"type":1,"title":"兄妹喝奶奶捡回的未开封饮料被送医抢救，饮料检出三甲基硅醇","text":"一个多月前，深圳宝安，6岁的哥哥和4岁妹妹喝了奶奶从外面垃圾桶捡回来的未开封的饮料，随即出现呕吐、腹痛症状，被送医抢救。\n\n4岁1个月大的中毒女孩病情严重\n10月22日，兄妹俩住院治疗38天，表姑妈黎女士告诉华商报大风新闻记者，“兄妹俩当时分着喝了一小部分，就上吐下泻，后来确定孩子喝了这个饮料中毒，里面检出了三甲基硅醇。”\n奶奶捡回饮料爷爷帮忙给打开\n兄妹俩只喝了一点就上吐下泻\n10月22日，表姑妈黎女士接受华商报大风新闻记者采访表示，6岁的表侄子和4岁的表侄女在深圳儿童医院住院抢救已经38天。\n黎女士介绍，事发9月16日，孩子60来岁的奶奶拾废品，捡回来一瓶未过期的饮料。\n“因为捡回来的饮料","images":[],"time":"2023-10-23T11:15:08.000+00:00","uid":1,"email":"3061588683@qq.com","username":"test","avatar":"","like":2,"collect":0},{"id":15,"type":3,"title":"请问项目的更新速度能不能再快一点","text":"太少了不够看啊，能不能再更新快一点！！！！！\n代码写多一点，我好拿来当毕设\n会撒娇大厦尽快的哈手机卡打撒\nadafawfafa方法为42\n","images":[],"time":"2023-10-23T08:55:02.000+00:00","uid":1,"email":"3061588683@qq.com","username":"test","avatar":"","like":0,"collect":1},{"id":10,"type":1,"title":"撒电话卡进度哈健康四大会计说","text":"大大叔大婶肯定撒户籍大刷卡机打撒科技大\n","images":[],"time":"2023-10-13T11:49:27.000+00:00","uid":1,"email":"3061588683@qq.com","username":"test","avatar":"","like":0,"collect":0},{"id":9,"type":2,"title":"测试我是测试帖子","text":"测试一下缓存是否生效\n","images":[],"time":"2023-10-13T11:35:43.000+00:00","uid":1,"email":"3061588683@qq.com","username":"test","avatar":"","like":0,"collect":0},{"id":8,"type":5,"title":"千万别在咸鱼上到手刀","text":"太坑了\n","images":[],"time":"2023-10-13T11:34:26.000+00:00","uid":1,"email":"3061588683@qq.com","username":"test","avatar":"","like":0,"collect":0}],"message":"请求成功"}
