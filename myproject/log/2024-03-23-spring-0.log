2024-03-23 21:10:26.942  INFO 24556 --- [http-nio-8080-exec-3] (84353814680965120) com.example.filter.RequestLogFilter      : 请求处理耗时: 102ms | 响应结果: {"id":84353814680965120,"code":200,"data":[{"id":19,"type":1,"title":"dadadad","text":"hhhhh\n","images":[],"time":"2024-03-23T13:08:29.000+00:00","uid":1,"username":"test","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":0,"collect":0},{"id":18,"type":1,"title":"新人报道，请多指教","text":"大家好，我今天第一次注册，请问需要注意什么？\n","images":[],"time":"2023-10-28T10:23:03.000+00:00","uid":2,"username":"user","avatar":null,"like":2,"collect":1},{"id":16,"type":1,"title":"兄妹喝奶奶捡回的未开封饮料被送医抢救，饮料检出三甲基硅醇","text":"一个多月前，深圳宝安，6岁的哥哥和4岁妹妹喝了奶奶从外面垃圾桶捡回来的未开封的饮料，随即出现呕吐、腹痛症状，被送医抢救。\n\n4岁1个月大的中毒女孩病情严重\n10月22日，兄妹俩住院治疗38天，表姑妈黎女士告诉华商报大风新闻记者，“兄妹俩当时分着喝了一小部分，就上吐下泻，后来确定孩子喝了这个饮料中毒，里面检出了三甲基硅醇。”\n奶奶捡回饮料爷爷帮忙给打开\n兄妹俩只喝了一点就上吐下泻\n10月22日，表姑妈黎女士接受华商报大风新闻记者采访表示，6岁的表侄子和4岁的表侄女在深圳儿童医院住院抢救已经38天。\n黎女士介绍，事发9月16日，孩子60来岁的奶奶拾废品，捡回来一瓶未过期的饮料。\n“因为捡回来的饮料","images":["http://localhost:8080/images/cache/20231023/6c95e362dbfe4b11b3b89a45f07bbd83","http://localhost:8080/images/cache/20231023/85903aad7db046a38d78ac5eb4714504"],"time":"2023-10-23T11:15:08.000+00:00","uid":1,"username":"test","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":2,"collect":2},{"id":15,"type":3,"title":"请问项目的更新速度能不能再快一点","text":"太少了不够看啊，能不能再更新快一点！！！！！\n\n代码写多一点，我好拿来当毕设\n\n会撒娇大厦尽快的哈手机卡打撒\n","images":["http://localhost:8080/images/cache/20231023/c292300bb3bc4adcb71fe88e13fea9c1","http://localhost:8080/images/cache/20231023/fca00bb202d7425fa60ce0eac2d7ee34"],"time":"2023-10-23T08:55:02.000+00:00","uid":1,"username":"test","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":0,"collect":1},{"id":10,"type":1,"title":"撒电话卡进度哈健康四大会计说","text":"大大叔大婶肯定撒户籍大刷卡机打撒科技大\n","images":[],"time":"2023-10-13T11:49:27.000+00:00","uid":1,"username":"test","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":0,"collect":0},{"id":9,"type":2,"title":"测试我是测试帖子","text":"测试一下缓存是否生效\n","images":[],"time":"2023-10-13T11:35:43.000+00:00","uid":1,"username":"test","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":0,"collect":0},{"id":8,"type":5,"title":"千万别在咸鱼上到手刀","text":"太坑了\n","images":[],"time":"2023-10-13T11:34:26.000+00:00","uid":1,"username":"test","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":0,"collect":0},{"id":6,"type":3,"title":"论坛出现超大BUG赶紧修","text":"为什么不能直接给我匹配一个女友，要同城的，最好同学校\n","images":[],"time":"2023-10-13T10:28:30.000+00:00","uid":1,"username":"test","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":0,"collect":0},{"id":5,"type":5,"title":"大家千万别在淘宝回收手机，坑死人","text":"我今天回收了一个最新款苹果手机，结果那边收到货之后说我手机各种有问题，只给我一般的价格出售，我说不接受，那边直接说把我手机都拆报废了，寄回来全是零件，后果自负，我只接好家伙！\n","images":[],"time":"2023-10-13T10:27:12.000+00:00","uid":1,"username":"test","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":0,"collect":0},{"id":4,"type":1,"title":"你们Navicat是不是在用盗版？","text":"千万别用了，小心数据库被勒索！\n","images":[],"time":"2023-10-13T10:23:49.000+00:00","uid":1,"username":"test","avatar":"/avatar/027ab822ae2f472da31cfd000344be0f","like":0,"collect":0}],"message":"请求成功"}
